{
  "name": "game-mbti",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-14",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": ["0 4 1 * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "game-mbti-results",
      "database_id": "33a8af67-6b99-4896-91bf-2560626cc79d"
    }
  ]
}
